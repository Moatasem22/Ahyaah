{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "insuranceNumber": { "type": "string" },
        "idNumber": { "type": "string" },
        "status": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Request": {
      "title": "Request",
      "description": "A service request submitted by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "date": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["uid", "type", "status", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["INFO", "SUCCESS", "WARNING", "ALERT"] },
        "date": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "url": { "type": "string" }
      },
      "required": ["uid", "title", "body", "type", "date", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Service requests"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
